model User {
  id            String           @id @default(uuid())
  name          String           @db.VarChar(255)
  email         String           @unique
  password      String
  phone         String
  address       String
  role          Role             @default(CUSTOMER)
  active_status UserActiveStatus @default(ACTIVE)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}
